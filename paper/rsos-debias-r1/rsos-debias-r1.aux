\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Residual assessments of the proportional baseline model across data sources. First row: hexagonal maps of residual bias by LAD (normalised to \([-1,1]\) for visualisation), where red indicates areas over-represented relative to baseline expectation and blue indicates under-represented areas. Moran's \(I\) and associated \(p\)-values are computed on unstandardised residuals. Second row: residual bias plotted against the contextual covariate with the lowest GAM AIC in each dataset, with fitted linear (dotted black) and GAM (solid red) trends.}}{16}{figure.4}\protected@file@percent }
\newlabel{fig:residual-maps}{{4}{16}{Residual assessments of the proportional baseline model across data sources. First row: hexagonal maps of residual bias by LAD (normalised to \([-1,1]\) for visualisation), where red indicates areas over-represented relative to baseline expectation and blue indicates under-represented areas. Moran's \(I\) and associated \(p\)-values are computed on unstandardised residuals. Second row: residual bias plotted against the contextual covariate with the lowest GAM AIC in each dataset, with fitted linear (dotted black) and GAM (solid red) trends}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Radial charts illustrating the importance of, and contribution to, explaining differences in population coverage bias across local authority districts.} The importance is estimated based on SHAP feature importance scores, calculated as the average absolute SHAP value per feature using an XGBoost machine learning algorithm. Average absolute SHAP values were normalised across individual data using minimum and maximum scores, to ensure comparability across data sources. First column displays the estimates for all data sources and model features. Subsequent columns highlight features scoring SHAP values over 0.5 within a 0-1 range for individual data sources.}}{17}{figure.5}\protected@file@percent }
\newlabel{fig:radialplots}{{5}{17}{\textbf {Radial charts illustrating the importance of, and contribution to, explaining differences in population coverage bias across local authority districts.} The importance is estimated based on SHAP feature importance scores, calculated as the average absolute SHAP value per feature using an XGBoost machine learning algorithm. Average absolute SHAP values were normalised across individual data using minimum and maximum scores, to ensure comparability across data sources. First column displays the estimates for all data sources and model features. Subsequent columns highlight features scoring SHAP values over 0.5 within a 0-1 range for individual data sources}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Top ranked model features contributing to explaining population coverage bias across local authority districts from an XGboost model.} A) beeswarm plots of SHAP feature values displaying the relative importance and direction of influence of the top 20 contextual features on the extent of population coverage bias. Features are ranked by their mean absolute SHAP value, with colours indicating feature values (low to high). B) SHAP dependence plots for the top six features based on their mean absolute SHAP value, illustrating the marginal effect of variation in each predictor on population coverage bias. Local polynomial regression modelling was used to represent local trends with 95\% confidence intervals. Each point represents a local authority district.}}{18}{figure.6}\protected@file@percent }
\newlabel{fig:shap-plots}{{6}{18}{\textbf {Top ranked model features contributing to explaining population coverage bias across local authority districts from an XGboost model.} A) beeswarm plots of SHAP feature values displaying the relative importance and direction of influence of the top 20 contextual features on the extent of population coverage bias. Features are ranked by their mean absolute SHAP value, with colours indicating feature values (low to high). B) SHAP dependence plots for the top six features based on their mean absolute SHAP value, illustrating the marginal effect of variation in each predictor on population coverage bias. Local polynomial regression modelling was used to represent local trends with 95\% confidence intervals. Each point represents a local authority district}{figure.6}{}}
