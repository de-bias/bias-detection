\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Extent and spatial distribution of population bias across local authority districts in the UK. A) Hexagon cartogram of the size of population coverage bias across local authority districts. Values closer to 100 indicate lower population coverage relative to the census benchmark. \(I\) represents the Moran's I and \(p\) denotes the associated p-value. B) Histogram of the distribution of the size of population bias. C) Scatter plot of the relationship between population size and size of bias.}}{14}{figure.3}\protected@file@percent }
\newlabel{fig:bias-size}{{3}{14}{Extent and spatial distribution of population bias across local authority districts in the UK. A) Hexagon cartogram of the size of population coverage bias across local authority districts. Values closer to 100 indicate lower population coverage relative to the census benchmark. \(I\) represents the Moran's I and \(p\) denotes the associated p-value. B) Histogram of the distribution of the size of population bias. C) Scatter plot of the relationship between population size and size of bias}{figure.3}{}}
\citation{iradukunda2025estimating,renninger2026}
